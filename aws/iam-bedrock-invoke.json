{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "BedrockConverseAndInvoke",
      "Effect": "Allow",
      "Action": [
        "bedrock:InvokeModel",
        "bedrock:InvokeModelWithResponseStream"
      ],
      "Resource": "*"
    },
    {
      "Sid": "TranscribeVoiceTesting",
      "Effect": "Allow",
      "Action": [
        "transcribe:StartTranscriptionJob",
        "transcribe:GetTranscriptionJob",
        "transcribe:DeleteTranscriptionJob"
      ],
      "Resource": "arn:aws:transcribe:*:*:transcription-job/farmer-chat-*"
    }
  ]
}
