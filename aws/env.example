# Copy to .env or export in shell / ECS task definition.

AWS_REGION=us-east-1

# App
# LLM_CONFIG_PATH=/app/config/llm.bedrock.example.yaml
# FARMER_CHAT_DATA_DIR=/data

# Optional named profile for local dev (also configurable in llm.yaml as aws_profile)
# AWS_PROFILE=my-dev-profile

# Not used for Bedrock (IAM instead). Still required if text.provider is openai/gemini:
# OPENAI_API_KEY=
# GEMINI_API_KEY=
